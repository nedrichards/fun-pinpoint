{
  "app-id": "com.nedrichards.pinpoint",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "command": "pinpoint",
  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--device=dri",
    "--socket=pulseaudio"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/share/man"
  ],
  "modules": [
    {
      "name": "pinpoint",
      "buildsystem": "meson",
      "config-opts": [
        "--prefix=/app",
        "-Dbuildtype=release"
      ],
      "sources": [
        {
          "type": "dir",
          "path": ".."
        }
      ]
    }
  ]
}
