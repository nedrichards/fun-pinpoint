<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.nedrichards.pinpoint</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>LGPL-2.1-or-later</project_license>
  <name>Pinpoint</name>
  <summary>@TAGLINE@</summary>
  <description>
    <p>
      Pinpoint helps hackers give excellent presentations. Write down the core
      ideas in concise plain text, arrange them in the editor of your choice,
      and tune the result while Pinpoint reloads it live.
    </p>
    <p>
      Keep the audience focused with big text and strong imagery. Add styled
      text, images, scalable graphics, videos, speaker notes, rehearsed
      timings, transitions, and commands when the talk needs them.
    </p>
    <p>
      Navigate with presentation clickers, media next and previous keys, or
      desktop applications which support MPRIS presentation control.
    </p>
  </description>
  <launchable type="desktop-id">com.nedrichards.pinpoint.desktop</launchable>
  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/nedrichards/fun-pinpoint/main/docs/screenshots/launch.png</image>
      <caption>Start a plain-text presentation from Pinpoint's setup screen</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/nedrichards/fun-pinpoint/main/docs/screenshots/audience.png</image>
      <caption>Audience view turns concise source into image-led slides</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/nedrichards/fun-pinpoint/main/docs/screenshots/speaker.png</image>
      <caption>Speaker view shows notes and adjacent-slide previews</caption>
    </screenshot>
  </screenshots>
  <branding>
    <color type="primary" scheme_preference="light">#9141ac</color>
    <color type="primary" scheme_preference="dark">#613583</color>
  </branding>
  <provides>
    <binary>pinpoint</binary>
    <mediatype>application/x-pinpoint</mediatype>
  </provides>
  <developer id="com.nedrichards">
    <name>Nick Richards</name>
  </developer>
  <url type="homepage">https://github.com/nedrichards/fun-pinpoint</url>
  <url type="bugtracker">https://github.com/nedrichards/fun-pinpoint/issues</url>
  <url type="vcs-browser">https://github.com/nedrichards/fun-pinpoint</url>
  <content_rating type="oars-1.1"/>
  <releases>
    <release version="@VERSION@" date="2026-07-14">
      <description>
        <p>Rebuilt on GTK 4 while retaining the Pinpoint presentation format.</p>
      </description>
    </release>
  </releases>
</component>
